
{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "plan",
    "allow": [
      "Read(./type_enforced/**)",
      "Edit(./type_enforced/**)",
      "Write(./type_enforced/**)",
      "Read(./test/**)",
      "Edit(./test/**)",
      "Write(./test/**)",
      "Read(./README.md)",
      "Edit(./README.md)",
      "Write(./README.md)"
    ],
    "deny": [
      "Read(.env)",
      "Read(*.env*)",
      "Read(**/*.env*)",
      "Read(**/*key*/**)",
      "Read(**/secret/**)",
      "Bash(rm *)",
      "Bash(git *)",
      "Read(cache/**)",
      "Read(dist/**)",
      "Read(**/__pycache__/**)",
      "Read(**/venv/**)",
      "Bash(./publish.sh)",
      "Bash(publish.sh)"
    ]
  }
}